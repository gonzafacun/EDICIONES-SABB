# functions/.env
# Variables de entorno para el backend (Firebase Functions)
# NUNCA commitear este archivo — está en .gitignore

# ─────────────────────────────────────────────────────────
# E-PAGOS
# ─────────────────────────────────────────────────────────
EPAGOS_EMPRESA=tu_empresa_id
EPAGOS_HASH=tu_hash_secreto
EPAGOS_MODO=sandbox         # "sandbox" o "produccion"

# ─────────────────────────────────────────────────────────
# URL del frontend (para redirección post-pago)
# ─────────────────────────────────────────────────────────
FRONTEND_URL=https://tu-proyecto.web.app
