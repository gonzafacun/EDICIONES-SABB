Set-Content -Path ".gitignore" -Value @"
# Dependencias
node_modules/
frontend/node_modules/

# Variables de entorno — NUNCA commitear
.env
.env.local
.env.production
frontend/.env.local

# Next.js build
frontend/.next/
frontend/out/

# Firebase (solo hosting)
.firebase/
firebase-debug.log
ui-debug.log

# Supabase
supabase/.env
supabase/functions/*/node_modules/

# Sistema operativo
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Documentación privada E-pagos (contiene credenciales)
epagos/

# Logs
*.log
npm-debug.log*
"@