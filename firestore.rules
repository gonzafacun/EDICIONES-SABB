rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // FUNCIONES AUXILIARES
    // ─────────────────────────────────────────

    // Verifica si el usuario autenticado es admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Verifica si el request viene autenticado (cualquier usuario)
    function isAuthenticated() {
      return request.auth != null;
    }

    // ─────────────────────────────────────────
    // PRODUCTOS
    // Lectura pública, escritura solo admin
    // ─────────────────────────────────────────
    match /productos/{productoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // CATEGORÍAS
    // Lectura pública, escritura solo admin
    // ─────────────────────────────────────────
    match /categorias/{categoriaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // PEDIDOS / ÓRDENES
    // Lectura y creación pública (sin auth),
    // solo admin puede actualizar estado
    // ─────────────────────────────────────────
    match /pedidos/{pedidoId} {
      allow read: if isAdmin();
      allow create: if true; // cualquier visitante puede crear un pedido
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // ADMINS
    // Solo readable/writable por admins
    // ─────────────────────────────────────────
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // CONFIGURACIÓN DEL SITIO
    // Lectura pública (banners, info), escritura admin
    // ─────────────────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
